# Copy to .env for docker compose local dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workplace_market
DATABASE_URL=postgresql://postgres:postgres@db:5432/workplace_market

NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
APP_SECRET_KEY=dev-secret-change-in-production
APP_ENV=dev

# Optional: production integrations
RESEND_API_KEY=
EMAIL_FROM=Workplace Market <onboarding@resend.dev>
HUNTER_API_KEY=
EMAIL_VERIFY_API_KEY=
