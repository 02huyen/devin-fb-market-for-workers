# Copy to .env and fill in. Load with: set -a && source .env && set +a
DATABASE_URL=            # e.g. postgresql://user:pass@host/db?sslmode=require (blank = local SQLite)
RESEND_API_KEY=          # Resend API key for magic-link emails (blank = dev inline link)
EMAIL_FROM=Workplace Market <onboarding@resend.dev>
HUNTER_API_KEY=          # Hunter.io key for company verification
APP_SECRET_KEY=          # session cookie signing secret (required in production)
APP_ENV=dev              # dev | production
FRONTEND_URL=http://localhost:3000
